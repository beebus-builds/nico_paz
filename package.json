{
  "name": "nicopaz",
  "version": "1.0.0",
  "private": true,
  "description": "Nico Paz WordPress Theme",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./assets/css/style.css --minify",
    "dev": "tailwindcss -i ./src/input.css -o ./assets/css/style.css --watch",
    "build:production": "NODE_ENV=production tailwindcss -i ./src/input.css -o ./assets/css/style.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17"
  }
}
